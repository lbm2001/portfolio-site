# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# typescript
*.tsbuildinfo
next-env.d.ts

# env
.env*.local

# OpenNext
.open-next

# playwright artifacts
/test-results/
/playwright-report/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example

# Resume: fetched at build time from the private source repo in config/resume.source.json
# (scripts/gen-resume-source.mjs) — NOT committed here. The parsed lib/resume-data.json
# stays committed so `next dev` and typecheck work without a fetch.
/public/resume.tex
/public/resume.pdf
# LaTeX byproducts from the optional local latexmk recompile.
/public/resume.aux
/public/resume.fdb_latexmk
/public/resume.fls
/public/resume.log
/public/resume.out
/public/resume.synctex.gz

# Blog post images fetched at build time from the blog repo (config/blog.sources.json)
# by scripts/gen-blog-data.mjs. The parsed lib/posts-data.json stays committed so
# `next dev` and typecheck work without a fetch.
/public/blog/

# Project images fetched at build time from the content repo (config/projects.sources.json)
# by scripts/gen-projects-data.mjs, which is their source of truth (<contentDir>/assets/).
# The parsed lib/projects-data.json stays committed so `next dev` and typecheck work
# without a fetch; with no GITHUB_TOKEN the text renders but the images 404.
/public/projects/

# Build ID: generated at build/dev startup (next.config.mjs) for the stale-tab
# reload guard. The deployed /build-id.json is revalidated (see public/_headers).
/public/build-id.json

# VLA embedding assets copied from node_modules/mini-vla/assets/ on predev/
# prebuild (scripts/copy-vla-assets.mjs). The mini-vla package is their source
# of truth.
/public/vla/

# Drop-in portfolio/ folders staged for the project repos (copy out, then delete)
portfolio-staging/
mockups/

# Conductor workspace scratch (see .context/)
.conductor/
