{
  "name": "portfolio-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/copy-vla-assets.mjs && node --experimental-strip-types scripts/gen-projects-data.mjs && node --experimental-strip-types scripts/gen-blog-data.mjs",
    "prebuild": "node scripts/copy-vla-assets.mjs && ./scripts/build-resume.sh",
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "preview": "./scripts/build-resume.sh && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "./scripts/build-resume.sh && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "./scripts/build-resume.sh && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tensorflow/tfjs": "^4.22.0",
    "katex": "^0.17.0",
    "marked": "^18.0.5",
    "mini-vla": "github:lbm2001/mini-vla#v0.1.0",
    "next": "^16.2.9",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "typescript": "5.7.3",
    "wrangler": "^4.107.0"
  }
}
