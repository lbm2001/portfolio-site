{
  "name": "portfolio-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "predev": "node scripts/copy-vla-assets.mjs && node --experimental-strip-types scripts/gen-projects-data.mjs && node --experimental-strip-types scripts/gen-blog-data.mjs",
    "prebuild": "node scripts/copy-vla-assets.mjs && ./scripts/build-resume.sh",
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:build": "opennextjs-cloudflare build",
    "e2e": "playwright test",
    "e2e:full": "VLA_FULL=1 playwright test",
    "smoke:live": "PLAYWRIGHT_BASE_URL=https://lukasmueller.dev playwright test",
    "preview": "./scripts/build-resume.sh && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "./scripts/build-resume.sh && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "./scripts/build-resume.sh && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tensorflow/tfjs": "^4.22.0",
    "katex": "^0.17.0",
    "marked": "^18.0.5",
    "mini-vla": "github:lbm2001/mini-vla#v0.4.0",
    "next": "^16.2.9",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "typescript": "5.7.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  }
}
