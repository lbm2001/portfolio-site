# https://developers.cloudflare.com/workers/static-assets/headers
# https://opennext.js.org/cloudflare/caching#static-assets-caching
/_next/static/*
  Cache-Control: public,max-age=31536000,immutable

# mini-vla's embedding assets. Safe to cache forever ONLY because the path
# carries the package version (scripts/copy-vla-assets.mjs writes
# public/vla/<version>/, Hero.tsx requests /vla/<version>/): a new release
# fetches a new URL rather than a stale body from someone's cache. Since v0.4.0
# the package validates these bytes against constants compiled into its JS, so
# serving one release's embeddings to another release's code is a hard error
# rather than a hero that trains on noise.
/vla/*
  Cache-Control: public,max-age=31536000,immutable

# Stale-tab reload guard: a tab left open across a deploy fetches this on
# visibilitychange and reloads if the id no longer matches the one baked into
# its JS bundle. Must revalidate so the CDN always serves the current deploy's
# value — the browser fetch already uses cache:"no-store". This path is a
# static string here (this file can't import lib/build-id.ts's BUILD_ID_PATH
# constant, which next.config.mjs and Hero.tsx both use) — keep it in sync by
# hand if that constant ever changes.
/build-id.json
  Cache-Control: public,max-age=0,must-revalidate
